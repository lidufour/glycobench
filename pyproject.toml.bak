[project]
name = "glycobench"
version = "0.1.0"
description = "Benchmark GlycoShield / GlycoShape against experimental glycosylated PDB structures"
requires-python = ">=3.10"
dependencies = [
    "biopython>=1.83",
    "pyyaml>=6.0",
    "numpy>=1.26",
    "pandas>=2.2",
    "glycontact>=0.3.4",
]

[project.scripts]
glycobench-align-protein-frame = "glycobench.cli.align_protein_frame:main"
glycobench-build-analysis-manifest = "glycobench.cli.build_analysis_manifest:main"
glycobench-build-ingestion-qc = "glycobench.cli.build_ingestion_qc:main"
glycobench-read-glycoshape = "glycobench.cli.read_glycoshape:main"
glycobench-read-reference = "glycobench.cli.read_reference:main"
glycobench-read-glycoshield = "glycobench.cli.read_glycoshield:main"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
